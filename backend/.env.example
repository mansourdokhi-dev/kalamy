DATABASE_URL="postgresql://kalamy:kalamy_dev_password@localhost:5432/kalamy?schema=public"
PORT=3000
DEV_MODE=false
# Comma-separated list of allowed frontend origins for CORS. Defaults to the
# local dev ports (staff-web:5173, mobile web:8081) if unset — set this to
# the real deployed origin(s) in any non-local environment.
# CORS_ALLOWED_ORIGINS=https://staff.kalamy.app,https://app.kalamy.app

# --- OTP delivery ---
# Without these set, OtpDeliveryService silently skips delivery (a warning is
# logged) and OTP codes are only ever readable via DEV_MODE's devOtpCode or a
# direct DB lookup — real users cannot register/reset their password.
#
# Email (SMTP) — the only channel that can actually work today. Any standard
# SMTP account works (a transactional provider like SendGrid/Postmark/SES's
# SMTP interface, or even a plain mailbox with an app password).
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=no-reply@kalamy.app
# SMTP_PASSWORD=
# SMTP_FROM="كلامي <no-reply@kalamy.app>"
#
# WhatsApp (Meta Cloud API) — inert until both are set. Requires a Meta
# WhatsApp Business Account + a phone number registered to it; see
# docs/RUNBOOK.md for setup steps once ready.
# WHATSAPP_BUSINESS_API_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
